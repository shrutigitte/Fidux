PORT=3002
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sos_db
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=sos_db

# Auth
AUTH_JWT_SECRET=replace_with_a_long_random_secret
AUTH_JWT_EXPIRES_IN=7d
AUTH_BCRYPT_ROUNDS=10
AUTH_REQUIRE_EMAIL_VERIFIED=true
AUTH_VERIFY_TOKEN_EXPIRES_HOURS=48

# Public URLs
FIDUX_WEB_APP_URL=http://localhost:5173
FIDUX_API_PUBLIC_URL=http://localhost:3002/api
# AUTH_VERIFY_LINK_BASE_URL=http://localhost:3002/api/auth/verify-email

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google Sign-In
GOOGLE_CLIENT_ID=

# Email
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# RESEND_API_KEY=

# Storage / plugin thumbnails
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
CDN_BASE_URL=
PLUGIN_UPLOAD_URL_TTL_SECONDS=300

# TypeORM bootstrap behavior
TYPEORM_SYNCHRONIZE=false

# Optional plugin/dev script helpers
FIDUX_API_BASE=http://localhost:3002/api/plugin
FIDUX_DEV_EMAIL=fidux-dev@example.com
FIDUX_DEV_ORG_NAME=Fidux Dev Org
FIDUX_DEV_PROJECT_NAME=Fidux Dev Project
FIDUX_PLUGIN_PAT=
FIDUX_ORG_ID=
FIDUX_PROJECT_ID=
